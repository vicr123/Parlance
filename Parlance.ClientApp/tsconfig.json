{
  "compilerOptions": {
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "module": "es2022",
    "resolveJsonModule": true,
    "plugins": [
      {
        "name": "typescript-plugin-css-modules"
      }
    ],
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2023", "dom"],
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true
    //    "noImplicitAny": false
  },
  "typeAcquisition": {
    "enable": true
  },
  "include": ["src", "vite/**/*.d.ts"]
}
